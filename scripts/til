#!/usr/bin/env bash

declare location="${0%/*}"

source "$location/lib/yyyymmdd"

die() { echo "$1" >&2; exit 1; }

# Strict context check
[[ -n "$CONTEXT_TIL_PATH" ]]     || die "No writing context. Run: cch <context>"
[[ -n "$CONTEXT_TIL_TEMPLATE" ]] || die "CONTEXT_TIL_TEMPLATE not set for this context."

# Args
declare title="$1"
declare category="${2:-uncategorized}"

[[ -n "$title" ]] || die "Usage: til \"Title\" [category]"

next_num() {
  local max=0 num
  for f in "$CONTEXT_TIL_PATH"/*.md; do
    [[ -f "$f" ]] || continue
    num=$(basename "$f" .md)
    [[ "$num" =~ ^[0-9]+$ ]] || continue
    (( num > max )) && max=$num
  done
  echo $(( max + 1 ))
}

render_template() {
  local date
  date=$(yyyymmdd)
  while IFS= read -r line; do
    line="${line//__TITLE__/$title}"
    line="${line//__DATE__/$date}"
    line="${line//__CATEGORY__/$category}"
    printf '%s\n' "$line"
  done < "$CONTEXT_TIL_TEMPLATE"
}

main() {
  local n filepath
  n=$(next_num)
  filepath="$CONTEXT_TIL_PATH/$n.md"

  render_template > "$filepath"

  ${EDITOR:-nvim} "$filepath"
}

main
